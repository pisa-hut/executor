MANAGER_URL=http://${MANAGER_HOST}:${MANAGER_PORT}/manager

# PISA_DATA_DIR no longer holds dynamic task inputs — maps, scenarios,
# and configs all come from the manager over HTTP. It is only used as
# the default base for RMLIB_PATH (the libesminiRMLib.so binary) and
# SIF images consumed by the container runtime.
PISA_DATA_DIR=/opt/pisa
RMLIB_PATH=${PISA_DATA_DIR}/lib/libesminiRMLib.so
